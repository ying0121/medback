DB_PASSWORD=
DB_NAME=
DB_CHARSET=
DB_TIMEZONE=

OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_MAX_COMPLETION_TOKENS=
OPENAI_TRANSCRIPTION_MODEL=
OPENAI_TTS_MODEL=
OPENAI_TTS_VOICE=
OPENAI_TTS_FORMAT=

TWILIO_CALL_CALLBACK_URL=
TWILIO_CALL_NOTICE=

# ── Inbound PSTN → live-streaming voice bot ───────────────────────────────────
# Twilio phone number: Voice webhook → POST https://YOUR_HOST/api/twilio/voice/inbound
# Media Stream WebSocket:             wss://YOUR_HOST/api/twilio/voice/stream
# Greeting for Media Stream bot; use $clinic_name$ for DB clinics.name (or acronym)
TWILIO_INBOUND_VOICE_GREETING=
# If name/acronym missing in DB, $clinic_name$ is replaced with this (else "our clinic")
TWILIO_INBOUND_GREETING_CLINIC_FALLBACK=
# Deepgram streaming STT (nova-2-phonecall, μ-law 8 kHz)
DEEPGRAM_API_KEY=
# Silence duration (ms) before Deepgram fires endpointing; lower = faster response (default 600)
VAD_SILENCE_MS=600
# Start LLM early when partial transcript reaches this many chars (default 120)
INTERIM_FLUSH_CHARS=120
# Bot base system prompt (clinic context + knowledge are appended automatically)
BOT_SYSTEM_PROMPT=
# Optional faster model for inbound only (defaults to OPENAI_MODEL)
OPENAI_INBOUND_MODEL=
# Max completion tokens for inbound; lower = faster (default 200)
OPENAI_INBOUND_MAX_COMPLETION_TOKENS=200
# ElevenLabs model for PSTN playback (default eleven_turbo_v2_5)
ELEVENLABS_INBOUND_TTS_MODEL=eleven_turbo_v2_5

# ElevenLabs TTS (admin preview / non-inbound defaults). Inbound PSTN uses ELEVENLABS_INBOUND_TTS_MODEL when set.
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_PREVIEW_TEXT=
# Public base URL Twilio can reach for <Play> MP3 (e.g. https://api.example.com). Use region close to Twilio for lower latency.
SERVER_URL=
# Optional dedicated WSS base for Twilio Media Streams (e.g. wss://voice.example.com).
# Use this when your main proxy/domain does not forward WebSocket Upgrade headers correctly.
TWILIO_STREAM_WSS_URL=

EXAMPLE_DOCTOR_PHONE_NUMBER=
EXAMPLE_PATIENT_PHONE_NUMBER=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

SOCKET_IO_PATH=
WEBSOCKET_CHAT_URL=
ALLOWED_ORIGINS=
ALLOWED_WS_ORIGINS=
SOCKET_IO_PING_INTERVAL_MS=
SOCKET_IO_PING_TIMEOUT_MS=
WS_PING_INTERVAL_MS=
WS_MAX_MISSED_PONGS=

OPENAI_SYSTEM_PROMPT=