# ── Inbound PSTN → live-streaming voice bot ───────────────────────────────────
# Twilio phone number: Voice webhook → POST https://YOUR_HOST/api/twilio/voice/inbound
# Media Stream WebSocket:             wss://YOUR_HOST/api/twilio/voice/stream
# System-wide default inbound phone greeting (PSTN calls).
# Per-clinic greetings: Admin → Clinics → greeting icon → Inbound tab.
# Placeholders: $clinic_name$ $clinic_acronym$ $clinic_city$
TWILIO_INBOUND_VOICE_GREETING=
# System-wide default web chat greeting (Socket.IO connect).
CHAT_GREETING=
# Fallback when $clinic_name$ / $clinic_acronym$ cannot be resolved (else "our clinic")
TWILIO_INBOUND_GREETING_CLINIC_FALLBACK=
# OpenAI Realtime API — inbound PSTN voice bot (STT + LLM + TTS in one session).
# Models: gpt-realtime-1.5 (default, low-latency phone), gpt-realtime-2, gpt-realtime, gpt-realtime-mini
OPENAI_REALTIME_MODEL=gpt-realtime-1.5
# Default voice when clinic has none set (marin, cedar, alloy, ash, ballad, coral, echo, sage, shimmer, verse)
OPENAI_REALTIME_VOICE=marin
OPENAI_REALTIME_TRANSCRIPTION_MODEL=gpt-4o-mini-transcribe
# Silence (ms) before Realtime server VAD ends a turn (default 500)
VAD_SILENCE_MS=300
# Bot base system prompt (clinic context + knowledge are appended automatically)
BOT_SYSTEM_PROMPT=
# End-call classifier (0=off). When user says goodbye, plays farewell and hangs up.
INBOUND_END_CALL_ENABLED=1
# Preview text for admin voice picker
OPENAI_VOICE_PREVIEW_TEXT=
# Public base URL Twilio can reach for <Play> MP3 (e.g. https://api.example.com). Use region close to Twilio for lower latency.
SERVER_URL=
# Optional dedicated WSS base for Twilio Media Streams (e.g. wss://voice.example.com).
# Use this when your main proxy/domain does not forward WebSocket Upgrade headers correctly.
TWILIO_STREAM_WSS_URL=

EXAMPLE_DOCTOR_PHONE_NUMBER=
EXAMPLE_PATIENT_PHONE_NUMBER=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=
# Comma-separated recipients for chat appointment request notifications
APPOINTMENT_NOTIFY_EMAILS=roswellg@gmail.com,uross1026@gmail.com

SOCKET_IO_PATH=
WEBSOCKET_CHAT_URL=
ALLOWED_ORIGINS=
ALLOWED_WS_ORIGINS=
SOCKET_IO_PING_INTERVAL_MS=
SOCKET_IO_PING_TIMEOUT_MS=
WS_PING_INTERVAL_MS=
WS_MAX_MISSED_PONGS=
# 1 = allow polling→websocket upgrade (default). 0 = polling only (use behind nginx without WS upgrade).
SOCKET_IO_ALLOW_UPGRADES=1

OPENAI_SYSTEM_PROMPT=