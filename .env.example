PORT=

DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CHARSET=
DB_TIMEZONE=

OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_MAX_COMPLETION_TOKENS=
OPENAI_TRANSCRIPTION_MODEL=
OPENAI_TTS_MODEL=
OPENAI_TTS_VOICE=
OPENAI_TTS_FORMAT=

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_API_KEY_SID=
TWILIO_API_KEY_SECRET=
TWILIO_TWIML_APP_SID=
TWILIO_PHONE_NUMBER=
ALERT_PHONE_NUMBER=
TWILIO_CALL_CALLBACK_URL=
TWILIO_CALL_NOTICE=

# Inbound PSTN → voice bot (configure on your Twilio number: Voice webhook POST)
# https://YOUR_HOST/api/twilio/voice/inbound
TWILIO_INBOUND_VOICE_GREETING=
# First <Gather> language before we detect caller language (single BCP-47, e.g. en-US)
TWILIO_INBOUND_INITIAL_SPEECH_LANGUAGE=
# Amazon Polly voice for inbound <Say> (multilingual); e.g. Polly.Joanna-Neural
TWILIO_INBOUND_DEFAULT_SAY_VOICE=
TWILIO_INBOUND_SPEECH_MODEL=
TWILIO_INBOUND_SPEECH_TIMEOUT=
TWILIO_INBOUND_SPEECH_HINTS=
TWILIO_INBOUND_MAX_REPLY_CHARS=
# While LLM+TTS runs: play optional hold URL then POST to /inbound-reply (default true). Set false for single-response TwiML only.
TWILIO_INBOUND_WAIT_BEFORE_REPLY=true
# HTTPS/HTTP URL to an audio file Twilio can <Play> (e.g. short loop). If unset, TWILIO_INBOUND_WAIT_SAY_TEXT is spoken.
# Example (Twilio-hosted sample): http://com.twilio.music.ambient.s3.amazonaws.com/aerosweep_-_B_chill_1_test.mp3
TWILIO_INBOUND_WAIT_AUDIO_URL=
# How many times to loop WAIT_AUDIO (1–20, default 2).
TWILIO_INBOUND_WAIT_AUDIO_LOOPS=2
# Spoken cue when WAIT_AUDIO_URL is empty (default: One moment please.)
TWILIO_INBOUND_WAIT_SAY_TEXT=
# Inbound latency: one LLM call for language + reply (default true). Set false for legacy two-call path.
TWILIO_INBOUND_MERGED_LLM=true
# Optional faster model for inbound only (defaults to OPENAI_MODEL)
OPENAI_INBOUND_MODEL=
# Max completion tokens for inbound (merged + split path); lower = faster
OPENAI_INBOUND_MAX_COMPLETION_TOKENS=450
# ElevenLabs model for PSTN playback (default eleven_turbo_v2_5). ELEVENLABS_TTS_MODEL is for other flows (e.g. admin).
ELEVENLABS_INBOUND_TTS_MODEL=eleven_turbo_v2_5
TWILIO_SAY_VOICE=
# Optional: MySQL clinics.id when inbound Twilio "To" does not match any clinic phone (digits)
TWILIO_INBOUND_CLINIC_DB_ID=

# ElevenLabs TTS (admin preview / non-inbound defaults). Inbound PSTN uses ELEVENLABS_INBOUND_TTS_MODEL when set.
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_PREVIEW_TEXT=
# Public base URL Twilio can reach for <Play> MP3 (e.g. https://api.example.com). Use region close to Twilio for lower latency.
SERVER_URL=
# Phase 2 (not implemented here): Twilio Media Streams over WebSocket for streaming STT/TTS and earliest audio playback.

EXAMPLE_DOCTOR_PHONE_NUMBER=
EXAMPLE_PATIENT_PHONE_NUMBER=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

SOCKET_IO_PATH=
WEBSOCKET_CHAT_URL=
ALLOWED_ORIGINS=
ALLOWED_WS_ORIGINS=
SOCKET_IO_PING_INTERVAL_MS=
SOCKET_IO_PING_TIMEOUT_MS=
WS_PING_INTERVAL_MS=
WS_MAX_MISSED_PONGS=

OPENAI_SYSTEM_PROMPT=