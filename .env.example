PORT=

DB_HOST=
DB_PORT=
DB_USER=
DB_PASSWORD=
DB_NAME=
DB_CHARSET=
DB_TIMEZONE=

OPENAI_API_KEY=
OPENAI_MODEL=
OPENAI_MAX_COMPLETION_TOKENS=
OPENAI_TRANSCRIPTION_MODEL=
OPENAI_TTS_MODEL=
OPENAI_TTS_VOICE=
OPENAI_TTS_FORMAT=

TWILIO_CALL_CALLBACK_URL=
TWILIO_CALL_NOTICE=

# ── Inbound PSTN → live-streaming voice bot ───────────────────────────────────
# Twilio phone number: Voice webhook → POST https://YOUR_HOST/api/twilio/voice/inbound
# Media Stream WebSocket:             wss://YOUR_HOST/api/twilio/voice/stream
# Greeting for Media Stream bot; use $clinic_name$ for DB clinics.name (or acronym)
TWILIO_INBOUND_VOICE_GREETING=
# If name/acronym missing in DB, $clinic_name$ is replaced with this (else "our clinic")
TWILIO_INBOUND_GREETING_CLINIC_FALLBACK=
# Deepgram streaming STT (μ-law 8 kHz). Default model: nova-2-phonecall (telephony).
DEEPGRAM_API_KEY=
DEEPGRAM_MODEL=nova-2-phonecall
# Silence (ms) before endpointing; 100–400 is typical for low latency (default 300)
VAD_SILENCE_MS=300
# Set to 1 to enable Deepgram smart_format (adds latency; default off)
DEEPGRAM_SMART_FORMAT=0
# Start LLM on partial transcript at this length (default 36; min 12)
INTERIM_FLUSH_CHARS=36
# Handoff delay (ms) when superseding an in-flight pipeline (default 20)
INBOUND_PIPELINE_HANDOFF_MS=20
# Bot base system prompt (clinic context + knowledge are appended automatically)
BOT_SYSTEM_PROMPT=
# Optional faster model for inbound only (defaults to OPENAI_MODEL)
OPENAI_INBOUND_MODEL=
# Max completion tokens for inbound; lower = faster (default 150)
OPENAI_INBOUND_MAX_COMPLETION_TOKENS=150
OPENAI_INBOUND_TEMPERATURE=0.6
# Min/max chars per TTS chunk from streamed LLM (defaults 28 / 100)
INBOUND_TTS_MIN_CHARS=28
INBOUND_TTS_MAX_CHARS=100
# End-call OpenAI classifier (0=off). Runs in parallel; skipped unless utterance looks like goodbye.
INBOUND_END_CALL_ENABLED=1
INBOUND_END_CALL_HEAD_START_MS=40
# ElevenLabs PSTN playback — flash model + max streaming latency optimization
ELEVENLABS_INBOUND_TTS_MODEL=eleven_flash_v2_5
ELEVENLABS_STREAMING_LATENCY=3

# ElevenLabs TTS (admin preview / non-inbound defaults). Inbound PSTN uses ELEVENLABS_INBOUND_TTS_MODEL when set.
ELEVENLABS_TTS_MODEL=eleven_multilingual_v2
ELEVENLABS_PREVIEW_TEXT=
# Public base URL Twilio can reach for <Play> MP3 (e.g. https://api.example.com). Use region close to Twilio for lower latency.
SERVER_URL=
# Optional dedicated WSS base for Twilio Media Streams (e.g. wss://voice.example.com).
# Use this when your main proxy/domain does not forward WebSocket Upgrade headers correctly.
TWILIO_STREAM_WSS_URL=

EXAMPLE_DOCTOR_PHONE_NUMBER=
EXAMPLE_PATIENT_PHONE_NUMBER=

SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=

SOCKET_IO_PATH=
WEBSOCKET_CHAT_URL=
ALLOWED_ORIGINS=
ALLOWED_WS_ORIGINS=
SOCKET_IO_PING_INTERVAL_MS=
SOCKET_IO_PING_TIMEOUT_MS=
WS_PING_INTERVAL_MS=
WS_MAX_MISSED_PONGS=

OPENAI_SYSTEM_PROMPT=